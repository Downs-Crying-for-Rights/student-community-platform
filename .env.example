# ===========================================
# 学生交流社区平台 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ---------- 数据库 ----------
# PostgreSQL 连接字符串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/student_community?schema=public"

# ---------- Redis ----------
# Redis 连接地址
REDIS_URL="redis://localhost:6379"

# ---------- NextAuth ----------
# NextAuth 密钥（用于加密会话，请使用随机字符串）
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-change-me"

# NextAuth 回调 URL（本地开发）
NEXTAUTH_URL="http://localhost:3000"

# ---------- SMTP 邮件服务 ----------
# 用于发送魔法链接认证邮件
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@example.com"

# ---------- 应用配置 ----------
# 应用运行端口
PORT=3000

# 节点环境
NODE_ENV="development"

# ---------- QQ OAuth 登录 ----------
# QQ 互联应用 APP ID 和 APP Secret
# 申请地址: https://connect.qq.com/
QQ_APP_ID="your-qq-app-id"
QQ_APP_SECRET="your-qq-app-secret"

# ---------- SMS 短信服务 ----------
# 测试模式：true 时使用固定验证码 888888，不发送真实短信
SMS_TEST_MODE=true

# ---------- 阿里云 OSS 图片存储 ----------
# OSS 区域（如 oss-cn-hangzhou）
OSS_REGION="oss-cn-hangzhou"
# OSS Bucket 名称
OSS_BUCKET="your-bucket-name"
# OSS AccessKey ID
OSS_ACCESS_KEY_ID="your-access-key-id"
# OSS AccessKey Secret
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
# OSS Endpoint（可选，默认根据 region 自动生成）
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
# CDN 域名（可选，默认使用 OSS 直连域名）
OSS_CDN_DOMAIN="https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com"
